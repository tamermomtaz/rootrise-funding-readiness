# RootRise Funding Readiness System - Environment Configuration
# Copy this file to .env and customize as needed

# ===========================================
# Core Configuration
# ===========================================

# API Key for authentication (change in production!)
API_KEY=rootrise-dev-key-2024

# Database path (SQLite)
DATABASE_PATH=./data/funding_readiness.db

# ===========================================
# Notification Webhooks (Optional)
# ===========================================

# Slack webhook for urgent deadline notifications
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Discord webhook alternative
DISCORD_WEBHOOK_URL=

# ===========================================
# Email Configuration (Optional)
# For weekly digest emails
# ===========================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@rootrise.com
EMAIL_TO=tamer.momtaz@devoneers.org

# ===========================================
# Deployment Configuration
# ===========================================

# For Railway/Render deployment
# PORT=8000

# For production, set:
# DEBUG=false
# CORS_ORIGINS=https://rootrise.com,https://app.rootrise.com
